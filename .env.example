# Environment Configuration Template
# Copy this to .env and fill in the values for your environment

# ========== APPLICATION ==========
APP_ENV=production
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# ========== DATABASE ==========
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# If omitted, the app falls back to local SQLite at ./data/leads.db
DATABASE_URL=postgresql://lead_user:CHANGE_ME@postgres:5432/lead_scoring_db

# Database connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30

# ========== REDIS (Optional) ==========
# Redis connection string for caching
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ========== API CONFIGURATION ==========
# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# Workers (for production, use 2-4 * CPU cores)
API_WORKERS=4

# Request timeout in seconds
API_TIMEOUT=120

# ========== SECURITY ==========
# Change these in production!
API_KEY_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ========== MONITORING ==========
# Prometheus metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ========== BATCH PROCESSING ==========
# Batch size for bulk operations
BATCH_SIZE=100

# Batch processing timeout in seconds
BATCH_TIMEOUT_SECONDS=300

# Enable/disable batch processing
ENABLE_BATCH_PROCESSING=true

# ========== FEATURE FLAGS ==========
# Enable feedback loop
ENABLE_FEEDBACK_LOOP=true

# Enable drift detection
ENABLE_DRIFT_DETECTION=true

# Enable automatic retraining
ENABLE_AUTO_RETRAIN=true

# ========== NOTIFICATIONS (Optional) ==========
# Slack webhook for alerts
SLACK_WEBHOOK_URL=

# Email settings for alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ========== AWS (If using AWS) ==========
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket for storing models/data
S3_BUCKET_NAME=lead-scoring-prod

# ========== GCP (If using GCP) ==========
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_STORAGE_BUCKET=lead-scoring-prod

# ========== AZURE (If using Azure) ==========
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=lead-scoring
AZURE_STORAGE_ACCOUNT=
AZURE_CONTAINER_NAME=lead-scoring-data

# ========== TELEMETRY ==========
# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Datadog API key for monitoring (optional)
DD_API_KEY=
DD_SERVICE_NAME=lead-scoring

# New Relic license key (optional)
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=lead-scoring

# ========== DEVELOPMENT ==========
# Debug mode (never use in production)
DEBUG=false

# Reload on code changes
RELOAD=false

# ========== ADVANCED ==========
# Max request size in MB
MAX_REQUEST_SIZE=50

# Request rate limit per minute
RATE_LIMIT_PER_MINUTE=1000

# Database echo SQL (for debugging)
DB_ECHO_SQL=false
